# SteuerPilot — Umgebungsvariablen
# Kopiere diese Datei als .env und fülle die Werte ein.
# NIEMALS echte Werte in .env.example eintragen.

# Jetson KI-Backend
JETSON_HOST=192.168.x.x
JETSON_PORT=8000
JETSON_TOKEN=dein-token-hier

# Sync-Server (läuft auf Desktop)
SYNC_PORT=7425
SYNC_TOKEN=dein-sync-token-hier
