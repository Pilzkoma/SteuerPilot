{
  "name": "steuerpilot",
  "version": "0.1.0",
  "description": "Ganzjähriger Steuer- und Finanzassistent für Deutschland",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "rebuild": "electron-rebuild -f -w @journeyapps/sqlcipher",
    "postinstall": "electron-rebuild -f -w @journeyapps/sqlcipher"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@journeyapps/sqlcipher": "^5.3.1",
    "bonjour-service": "^1.2.1",
    "framer-motion": "^11.3.0",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config": "^1.0.2",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.3.1",
    "electron-builder": "^25.0.5",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.0",
    "vite": "^5.3.4",
    "vitest": "^2.0.5"
  },
  "build": {
    "appId": "de.steuerpilot.app",
    "productName": "SteuerPilot",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.finance"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
